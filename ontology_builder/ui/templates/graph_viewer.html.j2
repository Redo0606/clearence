    if (hubIds.size > 0) {
      var hubBtn = document.getElementById("hub-edges-toggle");
      if (hubBtn) {
        hubBtn.style.display = "flex";
        hubBtn.textContent = showAllHubEdges ? "Cap hub edges" : "Show all connections";
        hubBtn.addEventListener("click", function() {
          showAllHubEdges = !showAllHubEdges;
          hubBtn.textContent = showAllHubEdges ? "Cap hub edges" : "Show all connections";
          applyEdgeVisibility();
          applyStyles();
        });
      }
    }
    applyEdgeVisibility();
    applyLabelVisibility();
    applyEdgeLabelMode();
    applyStyles();

    function setLayout(mode) {
      layoutMode = mode;
      var layoutSelect = document.getElementById("layout-select");
      if (layoutSelect) layoutSelect.value = mode;
    }

    var layoutSelect = document.getElementById("layout-select");
    if (layoutSelect) {
      layoutSelect.value = defaultLayoutMode;
      layoutMode = defaultLayoutMode;
      layoutSelect.addEventListener("change", function() {
        var newMode = layoutSelect.value || "force";
        if (simulationFrozen && layoutMode === newMode) return;
        if (newMode === "galaxy") {
          runGalaxyLayout();
          return;
        }
        if (newMode === "elk") {
          if (typeof ELK === "undefined") {
            if (DEBUG) debugLog("ELK not loaded, falling back to hierarchy");
            setLayout("hierarchical");
            newMode = "hierarchical";
          } else {
            runElkLayout();
            return;
          }
        }
        var useHierarchy = newMode === "hierarchical";
        network.setOptions({
          layout: {
            hierarchical: useHierarchy ? { enabled: true, direction: "UD", sortMethod: "hubsize", levelSeparation: 180, nodeSpacing: 150, treeSpacing: 220, blockShifting: true, edgeMinimization: true, parentCentralization: true } : { enabled: false }
          },
          physics: {
            enabled: physicsEnabled,
            hierarchicalRepulsion: useHierarchy ? { centralGravity: 0.0, springLength: 150, springConstant: 0.01, nodeDistance: 180, damping: 0.09 } : undefined,
            barnesHut: useHierarchy ? undefined : { gravitationalConstant: -9000, centralGravity: 0.08, springLength: 280, springConstant: 0.035, damping: 0.45, avoidOverlap: 1 },
            stabilization: { enabled: true, iterations: physicsIters, updateInterval: 25, fit: true },
          },
        });
        simulationFrozen = false;
        layoutMode = newMode;
        network.once("stabilizationIterationsDone", function() {
          network.setOptions({ physics: { enabled: false } });
          simulationFrozen = true;
          network.fit({ animation: { duration: 300, easingFunction: "easeInOutCubic" } });
        });
      });
    }

    function runElkLayout() {
      if (typeof ELK === "undefined") return;
      if (hasCycles) {
        if (DEBUG) debugLog("Graph has cycles, falling back to force layout");
        setLayout("force");
        network.setOptions({ physics: { enabled: true }, layout: { hierarchical: { enabled: false } } });
        network.setOptions({ physics: { barnesHut: { gravitationalConstant: -9000, centralGravity: 0.08, springLength: 280, springConstant: 0.035, damping: 0.45, avoidOverlap: 1 }, stabilization: { enabled: true, iterations: physicsIters, updateInterval: 25, fit: true } } });
        simulationFrozen = false;
        network.once("stabilizationIterationsDone", function() {
          network.setOptions({ physics: { enabled: false } });
          simulationFrozen = true;
          network.fit({ animation: { duration: 300, easingFunction: "easeInOutCubic" } });
        });
        return;
      }
      var elk = new ELK();
      var visibleNodes = nodes.get().filter(function(n) { return !n.hidden; });
      var visibleEdges = edges.get().filter(function(e) { return !e.hidden; });
      var nodeIds = new Set(visibleNodes.map(function(n) { return n.id; }));
      var normalizedEdges = visibleEdges.filter(function(e) { return nodeIds.has(e.from) && nodeIds.has(e.to) && e.from !== e.to; }).map(function(e) { return { id: String(e.id), sources: [String(e.from)], targets: [String(e.to)] }; });
      var nodeWidth = 140, nodeHeight = 40;
      var elkGraph = { id: "root", layoutOptions: { "elk.algorithm": "layered", "elk.direction": "DOWN", "elk.spacing.nodeNode": "50", "elk.layered.spacing.nodeNodeBetweenLayers": "100", "elk.edgeRouting": "ORTHOGONAL", "elk.layered.allowNonTreeEdges": "true" }, children: visibleNodes.map(function(n) { var w = (n.width != null && n.width > 0) ? n.width : nodeWidth; var h = (n.height != null && n.height > 0) ? n.height : nodeHeight; return { id: String(n.id), width: w, height: h }; }), edges: normalizedEdges };
      elk.layout(elkGraph).then(function(layout) {
        if (!layout || !layout.children || layout.children.length === 0) { if (DEBUG) debugLog("ELK returned empty layout, fallback to force"); fallbackToForceLayout(); return; }
        var pos = {};
        var allSame = true, firstX = null, firstY = null;
        layout.children.forEach(function(c) { var x = (c.x != null) ? c.x : 0; var y = (c.y != null) ? c.y : 0; pos[c.id] = { x: x, y: y }; if (firstX == null) { firstX = x; firstY = y; } else if (x !== firstX || y !== firstY) allSame = false; });
        if (Object.keys(pos).length === 0) { if (DEBUG) debugLog("ELK produced no positions, fallback to force"); fallbackToForceLayout(); return; }
        if (allSame && Object.keys(pos).length > 1) { if (DEBUG) debugLog("ELK returned identical coordinates, fallback to force"); fallbackToForceLayout(); return; }
        network.setPositions(pos);
        network.setOptions({ physics: { enabled: false } });
        simulationFrozen = true;
        setLayout("elk");
        network.fit({ animation: { duration: 300, easingFunction: "easeInOutCubic" } });
      }).catch(function(err) { if (DEBUG) debugLog("ELK layout failed:", err); fallbackToForceLayout(); });
    }

    function fallbackToForceLayout() {
      setLayout("force");
      network.setOptions({ layout: { hierarchical: { enabled: false } }, physics: { enabled: physicsEnabled, barnesHut: { gravitationalConstant: -9000, centralGravity: 0.08, springLength: 280, springConstant: 0.035, damping: 0.45, avoidOverlap: 1 }, stabilization: { enabled: true, iterations: physicsIters, updateInterval: 25, fit: true } } });
      simulationFrozen = false;
      network.once("stabilizationIterationsDone", function() {
        network.setOptions({ physics: { enabled: false } });
        simulationFrozen = true;
        network.fit({ animation: { duration: 300, easingFunction: "easeInOutCubic" } });
      });
    }

    function runGalaxyLayout() {
      var visibleNodes = nodes.get().filter(function(n) { return !n.hidden; });
      var visibleEdges = edges.get().filter(function(e) { return !e.hidden; });
      var nodeIds = new Set(visibleNodes.map(function(n) { return n.id; }));
      var clusterMap = {};
      var clusterList = [];
      if (clusters && clusters.length > 0) {
        clusters.forEach(function(c, idx) {
          var members = (Array.isArray(c) ? c : []).filter(function(nid) { return nodeIds.has(nid); });
          if (members.length > 0) {
            members.forEach(function(nid) { clusterMap[nid] = clusterList.length; });
            clusterList.push(members);
          }
        });
      }
      var unclustered = visibleNodes.filter(function(n) { return clusterMap[n.id] == null; });
      if (unclustered.length > 0) clusterList.push(unclustered.map(function(n) { return n.id; }));
      var totalClusters = clusterList.length;
      var radiusBase = Math.max(350, Math.min(900, 100 + Math.sqrt(visibleNodes.length) * 25));
      var pos = {};
      var angleStep = (2 * Math.PI) / Math.max(1, totalClusters);
      clusterList.forEach(function(members, clusterIdx) {
        var cx = radiusBase * Math.cos(clusterIdx * angleStep);
        var cy = radiusBase * Math.sin(clusterIdx * angleStep);
        var memberAngle = (2 * Math.PI) / Math.max(1, members.length);
        var r = 60 + Math.min(150, members.length * 4);
        members.forEach(function(nid, mi) {
          pos[nid] = { x: cx + r * Math.cos(mi * memberAngle), y: cy + r * Math.sin(mi * memberAngle) };
        });
      });
      if (Object.keys(pos).length > 0) {
        network.setPositions(pos);
        network.setOptions({ physics: { enabled: false } });
        simulationFrozen = true;
        setLayout("galaxy");
        network.fit({ animation: { duration: 350, easingFunction: "easeInOutCubic" } });
      } else {
        fallbackToForceLayout();
      }
    }

    var viewModeSelect = document.getElementById("view-mode-select");
    if (viewModeSelect) {
      viewModeSelect.addEventListener("change", function() {
        viewMode = viewModeSelect.value;
        var allNodes = nodes.get();
        var nodeUpdates = [];
        for (var i = 0; i < allNodes.length; i++) {
          var n = allNodes[i];
          var hide = false;
          if (viewMode === "classes") hide = n.kind === "instance";
          else if (viewMode === "instances") hide = n.kind !== "instance";
          nodeUpdates.push({ id: n.id, hidden: hide });
        }
        if (nodeUpdates.length) nodes.update(nodeUpdates);
        applyEdgeVisibility();
        applyStyles();
        network.fit({ animation: { duration: 280, easingFunction: "easeInOutCubic" } });
      });
    }

    network.on("stabilizationIterationsDone", function() {
      network.setOptions({ physics: { enabled: false } });
      simulationFrozen = true;
      if (progressBar) progressBar.style.width = "100%";
      if (progressWrap) progressWrap.style.display = "none";
      if (DEBUG) {
        var pos = network.getPositions();
        var ids = Object.keys(pos);
        var nanCount = 0;
        ids.forEach(function(id) { var p = pos[id]; if (p && (isNaN(p.x) || isNaN(p.y))) nanCount++; });
        debugLog("Layout done. Positions: NaN=" + nanCount);
      }
      network.fit({ animation: { duration: 350, easingFunction: "easeInOutCubic" } });
      requestAnimationFrame(function() {
        container.classList.add("ready");
        applyLabelVisibility();
        applyEdgeVisibility();
        drawHullOverlay();
      });
      if (nodeCount > 100 && nodeCount <= 300) {
        var minimapEl = document.getElementById("minimap");
        if (minimapEl) {
          minimapEl.classList.add("visible");
          minimapEl.style.pointerEvents = "auto";
          var mmNodes = new vis.DataSet(nodes.get().map(function(n) { return { id: n.id, label: "", shape: "dot", size: 4, color: n.accent || C.accent }; }));
          var mmEdges = new vis.DataSet(edges.get().filter(function(e) { return !e.hidden; }).map(function(e) { return { from: e.from, to: e.to, width: 0.5 }; }));
          var mmNet = new vis.Network(minimapEl, { nodes: mmNodes, edges: mmEdges }, {
            physics: { enabled: false },
            interaction: { dragNodes: false, zoomView: true, dragView: true },
            nodes: { font: { size: 0 } },
            edges: { smooth: false }
          });
          mmNet.setPositions(network.getPositions());
          mmNet.fit();
        }
      }
    });

    setTimeout(function() { container.classList.add("ready"); }, 3000);

    if (preSelectNode && nodeCount > 0) {
      var found = nodes.get().some(function(n) { return n.id === preSelectNode; });
      if (found) {
        setTimeout(function() {
          enterSpotlight(preSelectNode);
          network.focus(preSelectNode, { scale: 1.2, animation: { duration: 400, easingFunction: "easeInOutCubic" } });
        }, 500);
      }
    }

    var nodeSearch = document.getElementById("node-search");
    if (nodeSearch) {
      nodeSearch.addEventListener("keydown", function(ev) {
        if (ev.key === "k" && (ev.metaKey || ev.ctrlKey)) { ev.preventDefault(); nodeSearch.focus(); }
      });
      nodeSearch.addEventListener("keydown", function(ev) {
        if (ev.key !== "Enter") return;
        var q = (nodeSearch.value || "").trim().toLowerCase();
        if (!q) return;
        var all = nodes.get();
        for (var i = 0; i < all.length; i++) {
          if (all[i].label && String(all[i].label).toLowerCase().indexOf(q) !== -1) {
            enterSpotlight(all[i].id);
            network.focus(all[i].id, { scale: 1.2, animation: { duration: 300 } });
            break;
          }
        }
      });
    }
  </script>
</body>
</html>
