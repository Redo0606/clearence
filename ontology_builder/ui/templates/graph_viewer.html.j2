      ? { enabled: physicsEnabled, hierarchicalRepulsion: { centralGravity: 0.0, springLength: 150, springConstant: 0.01, nodeDistance: 180, damping: 0.09 }, stabilization: { enabled: true, iterations: physicsIters, updateInterval: 50, fit: true } }
      : { enabled: physicsEnabled, solver: "barnesHut", barnesHut: { gravitationalConstant: -8000, centralGravity: 0.05, springLength: 220, springConstant: 0.04, damping: 0.5, avoidOverlap: 1 }, stabilization: { enabled: true, iterations: physicsIters, updateInterval: 50, fit: true }, minVelocity: 0.5 };
    var options = {
      autoResize: true,
      layout: {
        improvedLayout: true,
        hierarchical: useHierarchicalByDefault ? {
          enabled: true,
          direction: "UD",
