<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Ontology Graph Viewer</title>
  <script src="https://unpkg.com/vis-network@9.1.9/standalone/umd/vis-network.min.js" onerror="window.__viewerScriptError=true"></script>
  <script src="https://unpkg.com/elkjs@0.9.1/lib/elk.bundled.js" onerror="window.__elkScriptError=true"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/viewer/styles/viewer.css">
  <style>
{{ css_root | safe }}
  </style>
</head>
<body>
  <div id="app">
    <div id="header">
      <div>
        <h1>Ontology Graph Viewer</h1>
        <div id="stats" class="font-mono">{{ stats_html }}</div>
      </div>
      <div id="controls">
        <input id="node-search" type="search" placeholder="Jump to node… (⌘K)" class="ctrl-item font-mono" style="width:180px">
        <div class="ctrl-item"><div class="legend-dot" style="background:var(--accent)"></div> Class</div>
        <div class="ctrl-item"><div class="legend-dot" style="background:var(--accent-tertiary)"></div> Instance</div>
        <label class="ctrl-item" style="display: flex; align-items: center; gap: 4px;">
          <span style="color: var(--text-muted); font-size: 10px;">View:</span>
          <select id="view-mode-select" class="text-xs font-mono">
            <option value="full" selected>Full</option>
            <option value="classes">Classes only</option>
            <option value="instances">Instances</option>
          </select>
        </label>
        <div class="ctrl-sep"></div>
        <label class="ctrl-item" style="display: flex; align-items: center; gap: 4px;">
          <span style="color: var(--text-muted); font-size: 10px;">Edges:</span>
          <select id="edge-filter" class="text-xs font-mono" style="min-width: 100px;">
            <option value="all">All</option>
            <option value="intraCluster">Intra-cluster only</option>
            <option value="subClassOf">subClassOf only</option>
            <option value="type">type only</option>
            <option value="other">Other relations</option>
          </select>
        </label>
        <div class="ctrl-sep"></div>
        <label class="ctrl-item" style="display: flex; align-items: center; gap: 6px;">
          <span style="color: var(--text-muted); font-size: 10px;">N-hop:</span>
          <input id="depth-slider" type="range" min="1" max="5" value="1" style="width: 60px;">
          <span id="depth-badge" class="depth-badge font-mono">1</span>
        </label>
        <div class="ctrl-sep"></div>
        <button id="fit-btn" class="ctrl-item ctrl-btn" type="button">Fit</button>
        <button id="reset-focus-btn" class="ctrl-item ctrl-btn" type="button">Reset</button>
        <div class="ctrl-sep"></div>
        <button id="edge-label-toggle" class="ctrl-item ctrl-btn" type="button">Labels: ON</button>
        <button id="hub-edges-toggle" class="ctrl-item ctrl-btn" type="button" style="display:none;">Show all connections</button>
      </div>
    </div>
    <div id="graph-wrap">
      <div id="stabilization-progress"><div class="bar" id="stabilization-progress-bar"></div></div>
      <div id="spotlight-bg"></div>
      <canvas id="hull-overlay"></canvas>
      <div id="graph"></div>
      <div id="node-tooltip"></div>
      <div id="viewer-init-error"></div>
      <div id="minimap"></div>
    </div>
    <div id="detail-panel">
      <div class="detail-panel-header">
        <div class="detail-title">Selection</div>
        <button id="detail-panel-pin" type="button" class="ctrl-btn detail-pin-btn" title="Pin panel" aria-pressed="false">📌</button>
      </div>
      <div id="detail-content"><p style="color:var(--text-muted);">Click a node or edge to see provenance and quality.</p></div>
      <button id="detail-panel-close" type="button" class="ctrl-btn" style="margin-top:12px; display:none;">Close</button>
    </div>
  </div>
  <div id="toast-container" aria-live="polite"></div>
  <script>
    window.__GRAPH_DATA__ = {
      nodes: {{ nodes_json | safe }},
      edges: {{ edges_json | safe }},
      clusters: {{ clusters_json | safe }},
      edge_attrs: {{ edge_attrs_json | safe }},
      node_attrs: {{ node_attrs_json | safe }},
      hierarchy: {{ hierarchy_json | safe }},
      relations: {{ relations_json | safe }},
      isolated: {{ isolated_json | safe }},
      hub_ids: {{ hub_ids_json | default('[]') | safe }},
      has_cycles: {{ has_cycles_json | safe }},
      adjacency: {{ adjacency_json | default('null') | safe }},
      pre_select_node: {{ pre_select_node_json | safe }},
      depth: {{ depth_json | safe }},
      debug: {{ debug_json | safe }}
    };
  </script>
  <script type="module" src="/static/viewer/js/main.js"></script>
</body>
</html>
