        progressBar.style.width = pct + "%";
      }
    });

    var currentZoomScale = 1.0;
    var showAllHubEdges = false;

    function convexHull(points) {
      if (points.length < 3) return points;
      var cross = function(o, a, b) { return (a.x - o.x) * (b.y - o.y) - (a.y - o.y) * (b.x - o.x); };
      points.sort(function(a, b) { return a.x !== b.x ? a.x - b.x : a.y - b.y; });
      var lower = [], upper = [];
      for (var i = 0; i < points.length; i++) {
        while (lower.length >= 2 && cross(lower[lower.length - 2], lower[lower.length - 1], points[i]) <= 0) lower.pop();
        lower.push(points[i]);
      }
      for (var j = points.length - 1; j >= 0; j--) {
        while (upper.length >= 2 && cross(upper[upper.length - 2], upper[upper.length - 1], points[j]) <= 0) upper.pop();
        upper.push(points[j]);
      }
      lower.pop(); upper.pop();
      return lower.concat(upper);
    }

    function drawHullOverlay() {
      var hullCanvas = document.getElementById("hull-overlay");
      if (!hullCanvas || !clusters || clusters.length === 0 || nodeCount > 500) return;
      var ctx = hullCanvas.getContext("2d");
      var rect = hullCanvas.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return;
      hullCanvas.width = rect.width;
      hullCanvas.height = rect.height;
      ctx.clearRect(0, 0, rect.width, rect.height);
      var pos = network.getPositions();
      for (var c = 0; c < clusters.length; c++) {
        var clusterNodes = clusters[c];
        var pts = [];
        for (var i = 0; i < clusterNodes.length; i++) {
          var p = pos[clusterNodes[i]];
          if (p) {
            var dom = network.canvasToDOM({ x: p.x, y: p.y });
            pts.push({ x: dom.x - rect.left, y: dom.y - rect.top });
          }
        }
        if (pts.length >= 3) {
          var hull = convexHull(pts);
          ctx.fillStyle = clusterPalette[c % clusterPalette.length];
          ctx.beginPath();
          ctx.moveTo(hull[0].x, hull[0].y);
          for (var h = 1; h < hull.length; h++) ctx.lineTo(hull[h].x, hull[h].y);
          ctx.closePath();
          ctx.fill();
        }
      }
    }

    function computeEdgeHidden(e) {
      var rel = e.relation || "";
      var hideByFilter = false;
      if (edgeFilter === "subClassOf") hideByFilter = rel !== "subClassOf";
      else if (edgeFilter === "type") hideByFilter = rel !== "type" && rel !== "instanceOf";
      else if (edgeFilter === "other") hideByFilter = rel === "subClassOf" || rel === "type" || rel === "instanceOf";
      var hierarchyRels = ["subClassOf"];
      var structuralRels = ["subClassOf", "type", "instanceOf", "part_of", "contains"];
      var hideByZoom = false;
      if (currentZoomScale < 0.45) hideByZoom = hierarchyRels.indexOf(rel) === -1;
      else if (currentZoomScale < 0.75) hideByZoom = structuralRels.indexOf(rel) === -1;
      var hideByHub = false;
      if (!showAllHubEdges) {
        if (hubIds.has(e.from) && e.hubOutRank != null && e.hubOutRank >= HUB_EDGE_CAP) hideByHub = true;
        if (hubIds.has(e.to) && e.hubInRank != null && e.hubInRank >= HUB_EDGE_CAP) hideByHub = true;
      }
      return hideByFilter || hideByZoom || hideByHub;
    }

    function applyEdgeVisibility() {
      var allEdges = edges.get();
      var nodeMap = {};
      nodes.get().forEach(function(n) { nodeMap[n.id] = n; });
      var updates = [];
      for (var i = 0; i < allEdges.length; i++) {
        var e = allEdges[i];
        var hide = computeEdgeHidden(e);
        if (viewMode === "classes" && (e.relation || "") !== "subClassOf") hide = true;
        if (viewMode === "instances" && (e.relation || "") !== "type" && (e.relation || "") !== "instanceOf") hide = true;
        if (nodeMap[e.from] && nodeMap[e.from].hidden) hide = true;
        if (nodeMap[e.to] && nodeMap[e.to].hidden) hide = true;
        updates.push({ id: e.id, hidden: hide });
      }
      if (updates.length) edges.update(updates);
    }

