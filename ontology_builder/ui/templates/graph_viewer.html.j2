      var hoverWidth = edge.isDimmed ? 0.8 : Math.max(2.8, edge.width || 2.6);
      edges.update([{ id: edge.id, dashes: hoverDashes, width: hoverWidth, label: edgeLabelsOnHoverOnly ? (edge.relation || edge.label || "related_to") : getRelationLabel(edge) }]);
      applyStyles();
    });

    network.on("blurEdge", function(params) {
