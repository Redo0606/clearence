# LM Studio (default): start the local server in LM Studio (e.g. port 1234)
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=
ONTOLOGY_LLM_MODEL=phi-3-mini-4k-instruct

# For OpenAI cloud instead (required: OPENAI_API_KEY must be set):
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-key
# ONTOLOGY_LLM_MODEL=gpt-4o-mini

# Optional tuning (default INFO; set DEBUG for troubleshooting)
# LOG_LEVEL=INFO
# UPLOAD_MAX_SIZE_MB=20
# LLM_TIMEOUT_SECONDS=120
# LLM_MAX_RETRIES=3
# LLM_PARALLEL_WORKERS=  # Auto: 2 for local (LM Studio), 30 for ChatGPT/gpt-4o-mini (max throughput). Lower if hitting rate limits (Tier 1: 500 RPM).
# LLM_MAX_CHUNK_CHARS=  # Truncate chunks to avoid context overflow (0=no truncation). Auto: 600 for 4K models, 4000 for gpt-4o-mini.
# LLM_MAX_PROMPT_TOKENS=  # Soft token budget. Auto: 3000 for 4K models, 16000 for gpt-4o-mini.
# CHUNK_SIZE=  # Doc chunk size in chars. Auto: 1200 for 4K models, 4000 for gpt-4o-mini (fewer API calls = faster).
# CHUNK_OVERLAP=  # Overlap between chunks. Auto: 200 for 4K models, 400 for gpt-4o-mini.
# LLM_MAX_GRAPH_CHARS=  # Max graph JSON for relation inference. Auto: 3000/12000.
# LLM_MAX_TAXONOMY_CHARS=  # Max classes JSON for taxonomy. Auto: 2500/10000.
# QA_MAX_CONTEXT_CHARS=  # Max context for QA answers. Auto: 4000/16000.
# LLM_FORCE_TEXT_MODE=true  # Force plain-text when a call does not set response_format. json_schema requests override this.
