# LM Studio (default): start the local server in LM Studio (e.g. port 1234)
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=
ONTOLOGY_LLM_MODEL=phi-3-medium-128k-instruct

# For OpenAI cloud instead:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-key
# ONTOLOGY_LLM_MODEL=gpt-4o-mini

# Optional tuning
# LOG_LEVEL=DEBUG
# UPLOAD_MAX_SIZE_MB=20
# LLM_TIMEOUT_SECONDS=120
# LLM_MAX_RETRIES=3
# LLM_PARALLEL_WORKERS=4
